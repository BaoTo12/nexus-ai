# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexus:nexus123@postgres:5432/nexusai

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Ollama (local LLM) ────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
# Lightweight models that run on most machines (CPU-friendly)
CHAT_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text

# ── JWT Auth ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# ── LangSmith (free account at smith.langchain.com) ───────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=nexusai

# ── Frontend (Next.js) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
